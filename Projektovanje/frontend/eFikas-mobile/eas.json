{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
	  "env": {
        "EXPO_PUBLIC_API_SCHEME": "http",
		"EXPO_PUBLIC_API_ADDRESS": "192.168.100.1",
		"EXPO_PUBLIC_API_PORT": "8080"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
	  "env": {
        "EXPO_PUBLIC_API_SCHEME": "https",
		"EXPO_PUBLIC_API_ADDRESS": "efikas-team.com",
		"EXPO_PUBLIC_API_PORT": "443"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
